<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New 20-minute Franchise Application</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        margin: 0;
      }
      ul {
        list-style-type: none;
        padding: 0; 
        margin: 0; 
      }
    </style>
  </head>

  <body>
    <center>
      <table
        style="
          width: 100%;
          max-width: 550px;
          padding: 0 30px;
          overflow: hidden;
          color: #bcbcbc;
          background-color: #191510;
          font-family: 'Work Sans', sans-serif;
        "
        cellspacing="0"
        cellpadding="0"
        border="0"
        align="center"
      >
        <tr>
          <td style="text-align: center; padding: 30px 0">
            <img
              src="<%= connplexLogo %>"
              alt="company logo"
              width="150"
              height="35"
              style="margin: auto"
            />
          </td>
        </tr>
        <tr>
          <td
            style="
              background-color: #23211e;
              border-radius: 12px;
              padding: 30px 15px;
            "
          >
            <table
              width="100%"
              cellspacing="0"
              cellpadding="0"
              border="0"
              align="center"
            >
              <tr>
                <td
                  style="font-size: 20px; line-height: 26px; font-weight: 500"
                >
                New 20-minute Franchise Application
                </td>
              </tr>
              <tr>
                <td style="height: 20px">&nbsp;</td>
              </tr>
              <tr>
                <td style="font-size: 14px; line-height: 20px">
                    <p>A new user has applied for the 20-minute franchise:</p>
                    <ul>
                      <li><strong>Name:</strong> <%= name %></li>
                      <li><strong>Email:</strong> <%= email %></li>
                      <li><strong>Mobile Number:</strong> <%= mobileNumber %></li>
                      <li><strong>City:</strong> <%= city %></li>
                    </ul>
                </td>
              </tr>
              <tr>
                <td style="height: 20px">&nbsp;</td>
              </tr>
              
              <tr>
                <td style="text-align: center">
                  <p
                    style="font-size: 10px; line-height: 14px; margin: 0 0 7px"
                  >
                    Follow us on :
                  </p>
                  <div style="display: inline-flex;margin: auto;">
                  <a
                    href="https://www.facebook.com/connplex"
                    style="
                      text-decoration: none;
                      width: 25px;
                      height: 25px;
                      display: block;
                      margin: 0 3px;
                    "
                  >
                    <img
                      src="<%=facebookIcon %>"
                      alt="company logo"
                      width="25"
                      height="25"
                    />
                  </a>
                  <a
                    href="https://twitter.com/connplex1"
                    style="
                      text-decoration: none;
                      width: 25px;
                      height: 25px;
                      display: block;
                      margin: 0 3px;
                    "
                  >
                    <img
                      src="<%= twitterIcon %>"
                      alt="company logo"
                      width="25"
                      height="25"
                    />
                  </a>
                  <a
                    href="https://www.instagram.com/theconnplex/"
                    style="
                      text-decoration: none;
                      width: 25px;
                      height: 25px;
                      display: block;
                      margin: 0 3px;
                    "
                  >
                    <img
                      src="<%= instaIcon %>"
                      alt="company logo"
                      width="25"
                      height="25"
                    />
                  </a>
                  <a
                    href="https://www.youtube.com/channel/UC3DN8tu6EccEgoBkkOPvdPA"
                    style="
                      text-decoration: none;
                      width: 25px;
                      height: 25px;
                      display: block;
                      margin: 0 3px;
                    "
                  >
                    <img
                      src="<%= youtubeIcon %>"
                      alt="company logo"
                      width="25"
                      height="25"
                    />
                  </a>
                </div>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        <tr>
          <td
            style="
              text-align: center;
              padding: 20px 0;
              font-size: 12px;
              line-height: 16px;
              font-weight: 300;
            "
          >
            Copyright © <%= new Date().getFullYear() %>
          </td>
        </tr>
      </table>
    </center>
  </body>
</html>
