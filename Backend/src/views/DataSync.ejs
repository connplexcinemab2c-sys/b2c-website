<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet" />
  <title>Cinema Sync Status</title>
  <style>
    body {
      font-family: "Poppins", sans-serif;
      background: #f4f4f4;
      margin: 0;
      padding: 0;
    }
    .container {
      width: 100%;
      max-width: 800px;
      margin: 50px auto;
      background: #ffffff;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      background: #1e1e1d;
      color: #fff;
    }
    .header {
      text-align: center;
      padding: 15px 20px;
      /* border-bottom: 1px solid #e2e2e2; */
      background: #070000 !important;
    }
    .header img {
      max-width: 40%;
      width: 100%;
      height: 50px;
    }
    .header .status {
      font-weight: 900;
      font-size: 16px;
      padding-top: 20px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      /* margin-top: 20px; */
    }
    table, th, td {
      border: 1px solid #5a3b3b;
    }
    th, td {
      text-align: left;
      padding: 5px;
    }
    th {
      font-weight: 600;
    }
    tr:nth-child(even) {
      background: #f9f9f9;
    }
    .no-cinemas {
      text-align: center;
      font-weight: 500;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <img src="https://appworkdemo.com/designer-template/template-one/images/connplexLogo.png" alt="Connplex Logo" />
      <div class="status"><%= status %></div>
    </div>
    <table>
      <thead>
        <tr>
          <th>Cinema ID</th>
          <th>Cinema Name</th>
          <th>Sync Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (syncResults&&syncResults.length) { %>
          <% syncResults.forEach(cinema => { %>
            <tr>
              <td><%= cinema.cinemaId %></td>
              <td><%= cinema.cinemaName %></td>
              <td><%= cinema.syncStatus ? 'Success' : 'Failed' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="3" class="no-cinemas">No cinemas found</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>
